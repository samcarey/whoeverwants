{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/block-push-to-main.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$NTFY_TOPIC\" ] && curl -fsS --max-time 5 -d \"Claude is ready for your input\" -H \"Title: Claude Code\" \"https://ntfy.sh/$NTFY_TOPIC\" >/dev/null 2>&1 || true",
            "async": true,
            "timeout": 10
          }
        ]
      }
    ]
  }
}
