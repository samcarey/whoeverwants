# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# development artifacts
*.backup
*.png
!public/*.png

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

scratch

# python
__pycache__/
*.pyc
.venv/

# social test generated reports
social_tests/reports/

# iOS / Capacitor
# Pods are installed by CI; Podfile.lock IS committed for reproducibility.
ios/App/Pods/
# cap sync copies web assets to ios/App/public (generated; do not commit)
ios/App/public/
ios/.DS_Store
ios/App/build/
DerivedData/
